#!/usr/bin/env bash
# Auto-deploy to Cloudflare Pages before git push.
# Runs from repo root. Uses scripts/deploy.mjs which reads creds from env
# or from .cloudflare-token (gitignored).
set -e
cd "$(git rev-parse --show-toplevel)"
if [[ "${SKIP_DEPLOY:-}" == "1" ]]; then
  echo "[pre-push] SKIP_DEPLOY=1 set; skipping wrangler deploy."
  exit 0
fi
echo "[pre-push] Deploying to Cloudflare Pages (fuckyou.site)..."
node scripts/deploy.mjs
echo "[pre-push] Deploy complete. Continuing with git push."

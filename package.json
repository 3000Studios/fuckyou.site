{
  "name": "fuckyou-site",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "High-traffic humor + rant content site. AdSense-ready, SEO-optimized, deployed on Cloudflare Pages.",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build && node scripts/generate-sitemap.mjs",
    "preview": "vite preview",
    "lint": "eslint .",
    "deploy": "node scripts/deploy.mjs",
    "deploy:skip-build": "node scripts/deploy.mjs --skip-build",
    "deploy:create": "wrangler pages project create fuckyou-site --production-branch=main",
    "hooks:install": "git config core.hooksPath .githooks && git update-index --chmod=+x .githooks/pre-push .githooks/post-commit 2>nul || true",
    "worker:deploy": "npm --prefix workers/outrage-cron run deploy",
    "worker:dev": "npm --prefix workers/outrage-cron run dev"
  },
  "dependencies": {
    "framer-motion": "^11.11.17",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^2.0.5",
    "react-router-dom": "^6.28.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "wrangler": "^4.83.0"
  }
}
